rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "rrachidv4@gmail.com" && request.auth.token.email_verified == true);
    }

    // Datasets
    match /datasets/{datasetId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.uid == request.auth.uid;
      allow delete: if isDocOwner() || isAdmin();
    }

    // Guardians
    match /guardians/{guardianId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.uid == request.auth.uid;
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
