rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/datasets
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The ID of the user who owns this dataset
    //   - fileName: string (optional) - The original Excel file name
    //   - metadata: map (required) - Metadata about the dataset
    //   - students: list (required) - List of students and their absences
    //   - summaryCols: list (optional) - Summary columns
    //   - createdAt: number (required) - Timestamp when the dataset was uploaded
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function isValidDataset(data) {
      return data.userId is string &&
             data.metadata is map &&
             data.students is list &&
             data.createdAt is number;
    }

    match /users/{userId}/datasets/{datasetId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                       hasRequiredFields(['userId', 'metadata', 'students', 'createdAt']) &&
                       isValidDataset(request.resource.data) &&
                       uidUnchanged();
      allow update: if isOwner(userId) && 
                       isValidDataset(request.resource.data) &&
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId);
    }
  }
}
