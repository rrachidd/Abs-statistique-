{
  "entities": {
    "Dataset": {
      "title": "Dataset",
      "description": "A dataset of student absences for a specific class and month",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this dataset"
        },
        "fileName": {
          "type": "string",
          "description": "The original Excel file name"
        },
        "metadata": {
          "type": "object",
          "description": "Metadata about the dataset (class, month, etc.)"
        },
        "students": {
          "type": "array",
          "description": "List of students and their absences"
        },
        "summaryCols": {
          "type": "array",
          "description": "Summary columns"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when the dataset was uploaded"
        }
      },
      "required": ["userId", "metadata", "students"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User settings, such as guardians phone numbers",
      "type": "object",
      "properties": {
        "data": {
          "type": "object",
          "description": "The settings data"
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/Settings"
      },
      "description": "Settings for the user"
    },
    "/users/{userId}/datasets/{datasetId}": {
      "schema": {
        "$ref": "#/entities/Dataset"
      },
      "description": "Datasets uploaded by the user"
    }
  }
}
